{
  "expo": {
    "name": "get-off-soon",
    "slug": "get-off-soon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "getoffsoon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/590eadec-cdfd-4571-b1de-abdee71df1af"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.forkfork.tagotago",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0095F8",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "backgroundColor": "#1B1D22",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.forkfork.getoffsoon"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "590eadec-cdfd-4571-b1de-abdee71df1af"
      }
    },
    "owner": "fork-fork"
  }
}
